{
  "expo": {
    "name": "HumanAIze",
    "slug": "humanaize",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "humanaize",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "life.humanaize.app",
      "infoPlist": {
        "NSCameraUsageDescription": "HumanAIze uses the camera to scan barcodes and nutrition labels.",
        "NSPhotoLibraryUsageDescription": "HumanAIze accesses your photo library for progress photos.",
        "NSHealthShareUsageDescription": "HumanAIze reads health data to track your fitness goals.",
        "NSHealthUpdateUsageDescription": "HumanAIze writes health data to keep Apple Health in sync."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "life.humanaize.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE", "ACTIVITY_RECOGNITION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
